{
  "name": "playwright_libri",
  "version": "1.0.0",
  "description": "Projeto de automacao E2E com Playwright e TypeScript para validar fluxos, conteudos, auditoria de links e qualidade do site da Libri Incorporadora.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ci": "playwright test",
    "test:access": "playwright test tests/e2e/acessos.spec.ts",
    "test:broker": "playwright test tests/e2e/corretor.spec.ts",
    "test:contact": "playwright test tests/e2e/contato.spec.ts",
    "test:developments": "playwright test tests/e2e/empreendimentos.spec.ts",
    "test:hygiene": "playwright test tests/e2e/site-hygiene.spec.ts",
    "test:home": "playwright test tests/e2e/home.spec.ts",
    "test:links": "playwright test tests/e2e/link-check.spec.ts",
    "test:audit": "playwright test tests/e2e/link-check.spec.ts",
    "report": "playwright show-report",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality": "npm run format:check && npm run lint && npm run typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josafagonzaga/Playwright_Libri.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/josafagonzaga/Playwright_Libri/issues"
  },
  "homepage": "https://github.com/josafagonzaga/Playwright_Libri#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "eslint-plugin-playwright": "^2.10.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
